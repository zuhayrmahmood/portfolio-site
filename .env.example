# Contact form (Resend) — required for the /contact form to actually send email.
# Copy this file to `.env.local` and fill in the values. `.env.local` is gitignored.

# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=zuhayrmahmood01@gmail.com

# The "From" address shown on delivered emails.
# For real sending, verify your domain in Resend and use an address on it, e.g.
#   CONTACT_FROM_EMAIL="Zuhayr Mahmood <contact@zuhayrmahmood.me>"
# The default below (onboarding@resend.dev) only delivers test sends to your own
# Resend account email — fine for local testing, not for production.
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"
